	local gemsCur,   gemsGainLbl   = makeStatCard("💎", "Gems",   Color3.fromRGB(150,200,220))
	local tokensCur, tokensGainLbl = makeStatCard("🎫", "Tokens", Color3.fromRGB(220,200,100))

	makeSection("◈  EFFICIENCY  (por hora)")
	local kphLabel = makeCard("⚔️", "Kills / Hour",    "—", Color3.fromRGB(255,100,100))
	local sphLabel = makeCard("💪", "Strength / Hour", "—", Color3.fromRGB(100,220,100))

	-- ── FOOTER ───────────────────────────────────────────────
	local footer = Instance.new("Frame")
	footer.Size = UDim2.new(1,-14,0,FOOTER_H)
	footer.Position = UDim2.new(0,7,1,-(FOOTER_H+5))
	footer.BackgroundColor3 = CARD; footer.BorderSizePixel=0; footer.ZIndex=11; footer.Parent=win
	corner(footer,10); stroke(footer,BORDER,1,0)

	local BTN_H = isMobile and 36 or 42
	local BTN_Y = math.floor((FOOTER_H - BTN_H) / 2)

	local resetBtn = Instance.new("TextButton")
	resetBtn.Size = UDim2.new(1,-16,0,BTN_H); resetBtn.Position = UDim2.new(0,8,0,BTN_Y)
	resetBtn.BackgroundColor3 = RED_DARK; resetBtn.Text = "🔄  Reset Session"
	resetBtn.TextColor3 = WHITE; resetBtn.Font = Enum.Font.GothamBold
	resetBtn.TextSize = isMobile and 12 or 13; resetBtn.BorderSizePixel=0; resetBtn.ZIndex=12; resetBtn.Parent=footer
	corner(resetBtn, 8); stroke(resetBtn, RED, 1.5, 0.3)

	resetBtn.MouseEnter:Connect(function() resetBtn.BackgroundColor3 = RED end)
	resetBtn.MouseLeave:Connect(function() resetBtn.BackgroundColor3 = RED_DARK end)
	resetBtn.MouseButton1Click:Connect(function() self:Reset() end)

	-- ── BEHAVIOR LOOP (rápido) ───────────────────────────────
	local lastBehaviorUpdate = 0
	self.behaviorConnection = RunService.Heartbeat:Connect(function()
		if not self.statsActive then return end
		local now = tick()
		if now - lastBehaviorUpdate < 0.1 then return end
		lastBehaviorUpdate = now
		updateBehavior(self)
	end)

	-- ── UPDATE LOOP ──────────────────────────────────────────
	local lastUpdate = 0
	self.statsUpdateConnection = RunService.Heartbeat:Connect(function()
		if not self.statsActive then return end
		local now = tick()
		if now - lastUpdate < 0.5 then return end
		lastUpdate = now

		local stats = self:getStats()
		if not stats or not stats.Kills or not stats.Strength or not stats.Durability then return end

		local elapsed = self:getElapsed()
		timerLabel.Text = string.format("⏱️  %02d:%02d:%02d", elapsed.h, elapsed.m, elapsed.s)

		-- Health bar
		local hStr, hCur, hMax = self:getHealth()
		hbText.Text = hStr
		local pct = math.clamp(hCur / math.max(hMax, 1), 0, 1)
		hbFill.Size = UDim2.new(pct, 0, 1, 0)
		local r = math.floor(200 * (1 - pct) + 40 * pct)
		local g = math.floor(40  * (1 - pct) + 200 * pct)
		hbFill.BackgroundColor3 = Color3.fromRGB(r, g, 60)

		-- Valores atuais
		local kills      = stats.Kills.Value
		local strength   = stats.Strength.Value
		local durability = stats.Durability.Value
		local rebirths   = stats.Rebirths  and stats.Rebirths.Value  or 0
		local brawls     = stats.Brawls    and stats.Brawls.Value    or 0
		local agility    = stats.Agility   and stats.Agility.Value   or 0
		local gems       = stats.Gems      and stats.Gems.Value      or 0
		local tokens     = stats.Tokens    and stats.Tokens.Value    or 0

		local base = self.sessionData.stats
		local killsGain    = kills      - (base.Kills      or 0)
		local strengthGain = strength   - (base.Strength   or 0)
		local durabGain    = durability - (base.Durability or 0)
		local rebirthsGain = rebirths   - (base.Rebirths   or 0)
		local brawlsGain   = brawls     - (base.Brawls     or 0)
		local agilityGain  = agility    - (base.Agility    or 0)
		local gemsGain     = gems       - (base.Gems       or 0)
		local tokensGain   = tokens     - (base.Tokens     or 0)

		-- Session stat cards
		killsCur.Text    = FormatNumber(kills)    ; killsGainLbl.Text    = "+"..FormatNumber(killsGain)
		strengthCur.Text = FormatNumber(strength)  ; strengthGainLbl.Text = "+"..FormatNumber(strengthGain)
		durabCur.Text    = FormatNumber(durability); durabGainLbl.Text    = "+"..FormatNumber(durabGain)
		rebirthsCur.Text = FormatNumber(rebirths)  ; rebirthsGainLbl.Text = "+"..FormatNumber(rebirthsGain)
		brawlsCur.Text   = FormatNumber(brawls)    ; brawlsGainLbl.Text   = "+"..FormatNumber(brawlsGain)
		agilityCur.Text  = FormatNumber(agility)   ; agilityGainLbl.Text  = "+"..FormatNumber(agilityGain)
		gemsCur.Text     = FormatNumber(gems)      ; gemsGainLbl.Text     = "+"..FormatNumber(gemsGain)
		tokensCur.Text   = FormatNumber(tokens)    ; tokensGainLbl.Text   = "+"..FormatNumber(tokensGain)

		-- Efficiency
		local hours = elapsed.raw / 3600
		if hours > 0 then
			kphLabel.Text = FormatNumber(math.floor(killsGain    / hours))
			sphLabel.Text = FormatNumber(math.floor(strengthGain / hours))
		end

		-- Live status (behavior)
		local bt = self.behaviorTracker
		deathLabel.Text = tostring(bt.deathCount)
		jumpLabel.Text  = tostring(bt.jumpCount)

		local sessionTime = now - bt.startTime
		local jpm = sessionTime > 0 and (bt.jumpCount / sessionTime) * 60 or 0
		if jpm > 10 then
			jumpSpamLabel.Text = "SIM — Suspeito ⚠️"
			jumpSpamLabel.TextColor3 = Color3.fromRGB(255,60,60)
		else
			jumpSpamLabel.Text = "Normal"
			jumpSpamLabel.TextColor3 = GREEN
		end

		local afkSec = math.floor(bt.afkTime)
		if afkSec >= 3600 then
			afkLabel.Text = string.format("%dh %dm", math.floor(afkSec/3600), math.floor((afkSec%3600)/60))
		elseif afkSec >= 60 then
			afkLabel.Text = string.format("%dm %ds", math.floor(afkSec/60), afkSec%60)
		else
			afkLabel.Text = afkSec .. "s"
		end

		machineLabel.Text = self:getPVal("machineInUse")
		mapLabel.Text     = self:getPVal("currentMap")
	end)

	return true
end

return self
