-- ── BEHAVIOR TRACKING (importado do Stalker GUI) ─────────────
self.behaviorTracker = {
	lastPosition   = nil,
	lastMoveTime   = tick(),
	lastUpdateTime = tick(),
	afkTime        = 0,
	trainingTime   = 0,
	idleTime       = 0,
	deathCount     = 0,
	jumpCount      = 0,
	lastJumpTime   = 0,
	isJumping      = false,
	isDead         = false,
	startTime      = tick(),
}

local function initBehaviorTracker(self)
	local bt = self.behaviorTracker
	bt.lastPosition   = nil
	bt.lastMoveTime   = tick()
	bt.lastUpdateTime = tick()
	bt.afkTime        = 0
	bt.trainingTime   = 0
	bt.idleTime       = 0
	bt.deathCount     = 0
	bt.jumpCount      = 0
	bt.lastJumpTime   = 0
	bt.isJumping      = false
	bt.isDead         = false
	bt.startTime      = tick()
end

local function updateBehavior(self)
	local bt   = self.behaviorTracker
	local char = player.Character
	if not char then return end
	local hum  = char:FindFirstChild("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	if not (hum and root) then return end

	local pos = root.Position
	local now = tick()
	local dt  = now - bt.lastUpdateTime
	bt.lastUpdateTime = now

	if bt.lastPosition then
		if (pos - bt.lastPosition).Magnitude > 0.5 then
			bt.lastMoveTime = now
			bt.afkTime = 0
		else
			bt.afkTime = now - bt.lastMoveTime
			bt.idleTime = bt.idleTime + dt
		end
	end
	bt.lastPosition = pos

	local m = player:FindFirstChild("machineInUse")
	if m and m.Value then bt.trainingTime = bt.trainingTime + dt end

	if hum:GetState() == Enum.HumanoidStateType.Jumping then
		if not bt.isJumping then
			bt.isJumping   = true
			bt.jumpCount   = bt.jumpCount + 1
			bt.lastJumpTime = now
		end
	else
		bt.isJumping = false
	end

	if hum.Health <= 0 and not bt.isDead then
		bt.deathCount = bt.deathCount + 1
		bt.isDead = true
	elseif hum.Health > 0 then
		bt.isDead = false
	end
end

-- ── HELPERS ──────────────────────────────────────────────────
function self:getStats()
	local ls = player:FindFirstChild("leaderstats")
	if not ls then return nil end
	return {
		Kills      = ls:FindFirstChild("Kills"),
		Strength   = ls:FindFirstChild("Strength"),
		Rebirths   = ls:FindFirstChild("Rebirths"),
		Brawls     = ls:FindFirstChild("Brawls"),
		Durability = player:FindFirstChild("Durability"),
		Agility    = player:FindFirstChild("Agility"),
		Gems       = player:FindFirstChild("Gems"),
		Tokens     = player:FindFirstChild("Tokens"),
	}
end

function self:getHealth()
	local char = player.Character
	if not char then return "N/A", 0, 100 end
	local h = char:FindFirstChild("Humanoid")
	if h then return string.format("%.0f / %.0f", h.Health, h.MaxHealth), h.Health, h.MaxHealth end
	return "N/A", 0, 100
end

function self:getPVal(name)
	local v = player:FindFirstChild(name)
	if not v then return "N/A" end
	if v:IsA("BoolValue") then return v.Value and "Yes" or "No"
	elseif v:IsA("StringValue") then return v.Value ~= "" and v.Value or "None"
	elseif v:IsA("IntValue") or v:IsA("NumberValue") then return FormatNumber(v.Value) end
	return "N/A"
end

function self:startSession()
	local stats = self:getStats()
	if not stats or not stats.Kills or not stats.Strength or not stats.Durability then return false end
	self.sessionData.startTime = os.time()
	self.sessionData.stats = {
		Kills      = stats.Kills.Value,
		Strength   = stats.Strength.Value,
		Durability = stats.Durability.Value,
		Brawls     = stats.Brawls    and stats.Brawls.Value    or 0,
		Rebirths   = stats.Rebirths  and stats.Rebirths.Value  or 0,
		Agility    = stats.Agility   and stats.Agility.Value   or 0,
		Gems       = stats.Gems      and stats.Gems.Value      or 0,
		Tokens     = stats.Tokens    and stats.Tokens.Value    or 0,
	}
	initBehaviorTracker(self)
	return true
end

function self:getElapsed()
	local t = os.time() - self.sessionData.startTime
	return { raw = t, h = math.floor(t/3600), m = math.floor((t%3600)/60), s = t%60 }
end

-- ── DRAG ─────────────────────────────────────────────────────
local function makeDraggable(frame)
	local drag, ds, sp
	frame.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			drag = true; ds = i.Position; sp = frame.Position
			i.Changed:Connect(function()
				if i.UserInputState == Enum.UserInputState.End then drag = false end
			end)
		end
	end)
	frame.InputChanged:Connect(function(i)
		if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
			local d = i.Position - ds
			frame.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
		end
	end)
end

-- ── UI FACTORY HELPERS ────────────────────────────────────────
local function corner(p, r)
	local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 8); c.Parent = p
end
local function stroke(p, col, thick, trans)
	local s = Instance.new("UIStroke")
	s.Color = col or BORDER; s.Thickness = thick or 1; s.Transparency = trans or 0
	s.Parent = p; return s
end
local function lbl(p, txt, col, font, sz, size, pos, zi, align)
	local l = Instance.new("TextLabel")
	l.BackgroundTransparency = 1; l.BorderSizePixel = 0
	l.Text = txt; l.TextColor3 = col or WHITE
	l.Font = font or Enum.Font.GothamMedium; l.TextSize = sz or 13
	l.Size = size or UDim2.new(1,0,0,20); l.Position = pos or UDim2.new(0,0,0,0)
	l.ZIndex = zi or 5; l.TextXAlignment = align or Enum.TextXAlignment.Left
	l.TextWrapped = true; l.Parent = p; return l
end

-- ── HIDE / RESET ──────────────────────────────────────────────
function self:Hide()
	self.statsActive = false
	if self.statsUpdateConnection then self.statsUpdateConnection:Disconnect(); self.statsUpdateConnection = nil end
	if self.behaviorConnection     then self.behaviorConnection:Disconnect();     self.behaviorConnection = nil end
	if self.statsGui then self.statsGui:Destroy(); self.statsGui = nil end
end

function self:Reset()
	local ok = self:startSession()
	Notify({ Title = "🔄 Session Reset", Content = ok and "Nova sessão iniciada." or "Stats não encontradas ainda.", Duration = 2 })
	return ok
end

