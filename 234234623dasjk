-- ── Auto Collect ALL Brainrots ──────────────────────────────
mainTab:Toggle({
    Title = "⚡ Auto Collect ALL Brainrots",
    Desc  = "Automatically teleports and collects all active Brainrots",
    Icon  = "zap",
    Type  = "Checkbox",
    Value = false,
    Callback = function(state)
        _G.AutoCollect = state
        if not state then return end

        local player         = Players.LocalPlayer
        local ActiveBrainrots = workspace:WaitForChild("ActiveBrainrots", 5)

        if not ActiveBrainrots then
            warn("[AutoCollect] ActiveBrainrots not found in workspace.")
            _G.AutoCollect = false
            return
        end

        local CONFIG = {
            HOLD_TIME        = 1.5,
            TELEPORT_OFFSET  = Vector3.new(0, 5, 0),
            TELEPORT_WAIT    = 0.15,
            PROMPT_WAIT      = 0.1,
            LOOP_IDLE_WAIT   = 1,
            LOOP_CYCLE_WAIT  = 0.5,
        }

        local function holdE(duration)
            pcall(function() VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.E, false, game) end)
            task.wait(duration or CONFIG.HOLD_TIME)
            pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game) end)
        end

        local function findPrompt(obj)
            for _, child in ipairs(obj:GetDescendants()) do
                if child:IsA("ProximityPrompt") then return child end
            end
            return nil
        end

        local function interact(prompt)
            if prompt and prompt.Parent then
                local ok = pcall(fireproximityprompt, prompt)
                if ok then task.wait(CONFIG.PROMPT_WAIT) return end
            end
            holdE(CONFIG.HOLD_TIME)
        end

        task.spawn(function()
            while _G.AutoCollect do
                local char     = player.Character
                local rootPart = char and char:FindFirstChild("HumanoidRootPart")
                local humanoid = char and char:FindFirstChild("Humanoid")

                if rootPart and humanoid and humanoid.Health > 0 then
                    local items = ActiveBrainrots:GetChildren()

                    if #items == 0 then task.wait(CONFIG.LOOP_IDLE_WAIT) continue end

                    for _, item in ipairs(items) do
                        if not _G.AutoCollect then break end

                        local curChar  = player.Character
                        local curRoot  = curChar and curChar:FindFirstChild("HumanoidRootPart")
                        local curHuman = curChar and curChar:FindFirstChild("Humanoid")

                        if not curRoot or not curHuman or curHuman.Health <= 0 then break end
                        if not item or not item.Parent then continue end

                        local prompt = findPrompt(item)

                        local targetCFrame = nil
                        if item:IsA("BasePart") then
                            targetCFrame = item.CFrame
                        elseif item:IsA("Model") then
                            local ok, pivot = pcall(function() return item:GetPivot() end)
                            targetCFrame = ok and pivot or nil
                        end

                        if targetCFrame then
                            local ok = pcall(function()
                                curRoot.CFrame = targetCFrame + CONFIG.TELEPORT_OFFSET
                            end)
                            if ok then
                                task.wait(CONFIG.TELEPORT_WAIT)
                                if curHuman.Health > 0 then interact(prompt) end
                            end
                        end
                    end
                end

                task.wait(CONFIG.LOOP_CYCLE_WAIT)
            end
        end)
    end
})
-- ── Auto Collect Brainrots (Area 10) ───────────────────────
mainTab:Toggle({
    Title = "✨ Auto Collect Brainrots (Area 10)",
    Desc  = "Automatically teleports and collects all Brainrots in Area 10",
    Icon  = "zap",
    Type  = "Checkbox",
    Value = false,
    Callback = function(state)
        _G.AutoCollect = state
        if not state then return end

        task.spawn(function()
            local player          = Players.LocalPlayer
            local VisualBrainrots = workspace:FindFirstChild("VisualBrainrots")
            if not VisualBrainrots then return end

            local CONFIG = {
                HOLD_TIME           = 1.5,
                TELEPORT_OFFSET     = Vector3.new(0, 5, 0),
                TELEPORT_WAIT       = 0.1,
                LOOP_IDLE_WAIT      = 0.2,
                MAX_COLLECTED_CACHE = 500,
                ZONE_RADIUS         = 300,
                START_ZONE          = "10",
            }

            local collected = {}
            local zoneCenter = nil

            local function getHRP()
                local char = player.Character
                return char and char:FindFirstChild("HumanoidRootPart")
            end

            local function waitForCharacter(timeout)
                timeout = timeout or 10
                local hrp = getHRP()
                if hrp then return hrp end
                player.CharacterAdded:Wait()
                task.wait(0.2)
                local deadline = tick() + timeout
                repeat
                    hrp = getHRP()
                    if hrp then return hrp end
                    task.wait(0.1)
                until tick() > deadline
                return getHRP()
            end

            local function getPos(obj)
                if obj:IsA("BasePart") then return obj.Position end
                if obj:IsA("Model") then
                    if obj.PrimaryPart then return obj.PrimaryPart.Position end
                    local part = obj:FindFirstChildWhichIsA("BasePart", true)
                    if part then return part.Position end
                end
                return nil
            end

            local function getKey(name, pos)
                return name .. "_" .. math.round(pos.X) .. "_" .. math.round(pos.Z)
            end

            local function teleportTo(pos)
                local hrp = waitForCharacter()
                if not hrp then return false end
                hrp.CFrame = CFrame.new(pos + CONFIG.TELEPORT_OFFSET)
                task.wait(CONFIG.TELEPORT_WAIT)
                return true
            end

            -- ✅ CORRIGIDO: usa fireproximityprompt (funciona PC + Mobile)
            local function collectTarget(instance)
                local prompt = instance:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    pcall(fireproximityprompt, prompt)
                    task.wait(0.3)
                    return
                end
                -- Fallback PC caso não ache o prompt
                pcall(function() VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.E, false, game) end)
                task.wait(CONFIG.HOLD_TIME)
                pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game) end)
            end

            local function clearCacheIfNeeded()
                local count = 0
                for _ in pairs(collected) do count += 1 end
                if count >= CONFIG.MAX_COLLECTED_CACHE then collected = {} end
            end

            local function sortByDistance(queue)
                local hrp = getHRP()
                if not hrp then return queue end
                local origin = hrp.Position
                table.sort(queue, function(a, b)
                    return (a.position - origin).Magnitude < (b.position - origin).Magnitude
                end)
                return queue
            end

            local function insideZoneRadius(pos)
                if not zoneCenter then return true end
                local dist = (Vector3.new(pos.X, 0, pos.Z) - Vector3.new(zoneCenter.X, 0, zoneCenter.Z)).Magnitude
                return dist <= CONFIG.ZONE_RADIUS
            end

            local startZone = workspace.Zones and workspace.Zones[CONFIG.START_ZONE]
            if startZone and startZone:FindFirstChild("Part") then
                zoneCenter = startZone.Part.Position
                teleportTo(zoneCenter)
            end

            while _G.AutoCollect do
                clearCacheIfNeeded()

                local queue = {}
                for _, child in ipairs(VisualBrainrots:GetChildren()) do
                    local pos = getPos(child)
                    if pos and insideZoneRadius(pos) then
                        local key = getKey(child.Name, pos)
                        if not collected[key] then
                            table.insert(queue, {
                                instance = child,
                                name     = child.Name,
                                position = pos,
                                key      = key,
                            })
                        end
                    end
                end

                if #queue == 0 then task.wait(CONFIG.LOOP_IDLE_WAIT) continue end

                queue = sortByDistance(queue)

                for _, target in ipairs(queue) do
                    if not _G.AutoCollect then break end

                    if not target.instance or not target.instance.Parent then
                        collected[target.key] = true
                        continue
                    end

                    local ok = teleportTo(target.position)
                    if not ok then continue end

                    if not target.instance.Parent then
                        collected[target.key] = true
                        continue
                    end

                    collectTarget(target.instance)  -- ✅ substituído aqui
                    collected[target.key] = true
                    task.wait(0.01)
                end
            end
        end)
    end,
})

