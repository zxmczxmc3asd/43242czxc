local perfTab = Window:Tab({ Title = "Performance", Icon = "cpu" })

perfTab:Paragraph({ Title = "Boost FPS by reducing graphics quality and effects" })

local function collectDescendants(parent, filter)
    local result = {}
    for _, obj in pairs(parent:GetDescendants()) do
        if filter(obj) then table.insert(result, obj) end
    end
    return result
end

perfTab:Button({
    Title    = "🖼️ Remove All Textures",
    Desc     = "Hide all decals and textures",
    Icon     = "image-off",
    Callback = function()
        local targets = collectDescendants(Workspace, function(obj)
            return obj:IsA("Decal") or obj:IsA("Texture")
        end)
        for _, obj in ipairs(targets) do
            if obj and obj.Parent then obj.Transparency = 1 end
        end
        Notify({ Title = "✅ Textures Removed", Content = ("Removed %d textures!"):format(#targets), Duration = 3 })
    end
})

perfTab:Button({
    Title    = "🌑 Disable Shadows",
