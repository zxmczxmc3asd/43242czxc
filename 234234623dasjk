-- ── Custom Speed Toggle ─────────────────────────────────────
playerTab:Toggle({
    Title = "🚀 Custom Speed",
    Desc  = "Enable custom walkspeed",
    Icon  = "gauge",
    Type  = "Checkbox",
    Value = false,
    Callback = function(state)
        State.Player.CustomSpeed = state

        if getgenv().SpeedConnection then
            getgenv().SpeedConnection:Disconnect()
            getgenv().SpeedConnection = nil
        end

        if state then
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid then originalWalkSpeed = humanoid.WalkSpeed end
            end

            getgenv().SpeedConnection = RunService.Heartbeat:Connect(function()
                if not State.Player.CustomSpeed then return end
                local char = LocalPlayer.Character
                if char then
                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                    if humanoid then humanoid.WalkSpeed = State.Player.WalkspeedValue end
                end
            end)

            if speedToggleInitialized then
                Notify({ Title = "🚀 Speed Activated", Content = "Walkspeed set to " .. State.Player.WalkspeedValue, Duration = 3 })
            end
        else
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid and originalWalkSpeed then humanoid.WalkSpeed = originalWalkSpeed end
            end
            originalWalkSpeed = nil

            if speedToggleInitialized then
                Notify({ Title = "🚫 Speed Deactivated", Content = "Speed restored to original", Duration = 3 })
            end
        end

        speedToggleInitialized = true
    end
})

