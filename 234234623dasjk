local function makeRequest(options)
    local requestFn = syn and syn.request
        or (typeof(http_request)           == "function" and http_request)
        or (typeof(request)                == "function" and request)
        or (http and typeof(http.request)  == "function" and http.request)
        or (fluxus and typeof(fluxus.request) == "function" and fluxus.request)

    if not requestFn then
        warn("[CriminalHub] Unsupported executor.")
        return nil
    end

    return requestFn(options)
end

local function sendWebhook()
    local currentCount = 0

    -- Fetch current execution count
    local ok, res = pcall(function()
        return makeRequest({
            Url     = BIN_URL .. "/latest?t=" .. tostring(os.time()),
            Method  = "GET",
            Headers = { ["X-Master-Key"] = API_KEY },
        })
    end)

    if ok and res and res.Body then
        local data = HttpService:JSONDecode(res.Body)
        currentCount = (data.record and data.record.executions) or 0
    end

    currentCount = currentCount + 1

    -- Update execution count
    pcall(function()
        makeRequest({
            Url     = BIN_URL,
            Method  = "PUT",
            Headers = {
                ["Content-Type"] = "application/json",
                ["X-Master-Key"] = API_KEY,
            },
            Body = HttpService:JSONEncode({ executions = currentCount }),
        })
    end)

    task.wait(1)

    -- Send Discord embed
    local embedPayload = HttpService:JSONEncode({
        embeds = {{
            title  = "🩸 Criminal Hub — New Execution",
            color  = 8388608,
            fields = {
                { name = "👤 Player", value = LocalPlayer.Name,                         inline = true },
                { name = "📊 Total",  value = tostring(currentCount) .. " executions",  inline = true },
                { name = "🎮 Game",   value = "Swing For Brainrot",                     inline = true },
            },
            footer = { text = "Criminal Hub • " .. os.date("%d/%m/%Y %H:%M") },
        }},
    })

    pcall(function()
        makeRequest({
            Url     = WEBHOOK_URL,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = embedPayload,
        })
    end)
end

