-- Sempre trunca (floor), nunca arredonda pra cima
local function formatNumber(num)
	if num >= 1e9 then
		local n = math.floor(num / 1e7) / 100
		return string.format("%.2fB", n)
	elseif num >= 1e6 then
		local n = math.floor(num / 1e4) / 100
		return string.format("%.2fM", n)
	elseif num >= 1e3 then
		local n = math.floor(num / 100) / 10
		return string.format("%.1fK", n)
	else
		return tostring(math.floor(num))
	end
end

local function getNextGlitches(reb, rockName, count)
	local list = glitchLists[rockName]
	if not list then return {} end
	local out = {}
	for _, e in ipairs(list) do
		if e[1] > reb then
			table.insert(out, {reb=e[1], stats=e[2], preXP=e[3]})
			if #out >= (count or 3) then break end
		end
	end
	return out
end

