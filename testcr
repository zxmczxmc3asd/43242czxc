--                      CALCULATE LOGIC
-- ╚══════════════════════════════════════════════════════════════╝

calcBtn.MouseButton1Click:Connect(function()
	-- button press feedback
	tween(calcBtn, TweenInfo.new(0.07), {Size = UDim2.new(1, -6, 0, CALC_H - 3)})
	task.wait(0.07)
	tween(calcBtn, TweenInfo.new(0.1),  {Size = UDim2.new(1, 0,  0, CALC_H)})

	-- clear old results
	for _, c in ipairs(resultCards) do c:Destroy() end
	resultCards = {}
	resCon.Visible = false

	local raw = rebBox.Text:gsub("[^%d]", "")
	local reb = tonumber(raw)

	if not reb or reb < 0 then
		resCon.Visible = true
		makeCard("!", "INVALID INPUT", "Enter a valid rebirth number", C.RED,
			"Only positive integers accepted.", 1)
		return
	end

	local rock = rockData[selectedIdx]
	local list = glitchLists[rock.name]
	resCon.Visible = true
	local order = 1

	-- check exact match
	local exact = nil
	if list then
		for _, e in ipairs(list) do
			if e[1] == reb then exact = e; break end
		end
	end

	if exact then
		makeCard("✓", "GLITCH AVAILABLE",
			"+" .. exact[2] .. " stats per punch",
			C.GREEN,
			rock.icon .. "  " .. rock.name .. "  ·  Rebirth " .. reb .. "  ·  Pet lv " .. (exact[2]/5),
			order, C.GREEN_DIM)
		order += 1
		if exact[3] and exact[3] > 0 then
			makePreXP(exact[3], order); order += 1
		end
		makeCard("!", "WARNING",
			"Glitch disappears on disconnect!",
			C.RED,
			"Do NOT close the game while using the glitch",
			order)
	else
		-- best available below current reb
		local bestBelow = nil
		if list then
			for _, e in ipairs(list) do
				if e[1] <= reb then bestBelow = e else break end
			end
		end

		if bestBelow then
			local sub = "Rebirth " .. bestBelow[1] .. "  ·  " .. rock.icon .. " " .. rock.name
			if bestBelow[3] > 0 then
				sub = sub .. "\n  Requires +" .. bestBelow[3] .. " pre-loaded EXP"
			end
			makeCard("◈", "BEST GLITCH AVAILABLE NOW",
				"+" .. bestBelow[2] .. " stats per punch",
				C.BLUE, sub, order, C.BLUE_DIM)
			order += 1
		elseif list then
			makeCard("...", "NO GLITCH YET",
				"First glitch: rebirth " .. list[1][1],
				C.MUTED,
				rock.icon .. " " .. rock.name .. "  ·  Keep grinding!",
				order)
			order += 1
		end

		-- upcoming glitches
		local nexts = getNextGlitches(reb, rock.name, 3)
		if #nexts > 0 then
			local lines = {}
			for _, s in ipairs(nexts) do
				local pre = s.preXP > 0 and ("  + " .. s.preXP .. " pre-EXP") or ""
				table.insert(lines,
					"Reb " .. formatNumber(s.reb) ..
					"  →  +" .. s.stats .. " stats" ..
					"  (" .. formatNumber(s.reb - reb) .. " away)" .. pre
				)
			end
			makeCard("→", "UPCOMING GLITCH REBIRTHS",
				lines[1], C.AMBER,
				(#lines > 1 and table.concat(lines, "\n", 2) or nil),
				order)
			order += 1
		end

		makeCard("-", "REBIRTH " .. formatNumber(reb) .. " NOT IN LIST",
			"Not a glitchable rebirth for " .. rock.name,
			C.DIM,
			"Aim for one of the rebirths listed above",
			order)
	end
end)

