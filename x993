-- ══════════════════════════════════════
--  FPS  —  RenderStepped + os.clock()
--  (sem Heartbeat, mede tempo real de frame)
-- ══════════════════════════════════════

--[[
    Estratégia:
    • RenderStepped roda logo antes de cada frame ser renderizado,
      portanto dt aqui = tempo real entre dois frames = 1/FPS real.
    • Guardamos os últimos WINDOW frames num ring-buffer e calculamos
      a média → FPS suavizado e estável, sem pico de 1 frame.
    • Os.clock() é usado só para medir o ping do próprio loop caso queira,
      mas o dt do RenderStepped já é preciso o suficiente.
--]]

local FPS_WINDOW  = 30          -- quantos frames entram na média
local fpsBuffer   = {}          -- ring-buffer circular
local fpsBufIdx   = 0
local fpsSum      = 0
local fpsCurrent  = 0

local function initFpsBuffer()
    for i = 1, FPS_WINDOW do
        fpsBuffer[i] = 1 / 60   -- seed com 60 fps
    end
    fpsSum = FPS_WINDOW * (1 / 60)
end

local function updateFps(dt)
    fpsBufIdx = (fpsBufIdx % FPS_WINDOW) + 1
    fpsSum    = fpsSum - fpsBuffer[fpsBufIdx] + dt
    fpsBuffer[fpsBufIdx] = dt
    fpsCurrent = FPS_WINDOW / fpsSum   -- FPS médio dos últimos WINDOW frames
end

-- ══════════════════════════════════════
--  CONEXÕES & CICLO DE VIDA
-- ══════════════════════════════════════

local afkUpdateConn  = nil
local fpsConn        = nil
local afkStartTime   = nil

local function StartAFKWidget()
    afkStartTime = tick()
    initFpsBuffer()

    local gui, afkVal, pingVal, fpsVal = CreateAFKWidget()

    -- ── FPS: atualiza todo frame via RenderStepped ──
    fpsConn = RunService.RenderStepped:Connect(function(dt)
        updateFps(dt)
    end)

    -- ── UI: atualiza a cada ~0.25 s via task.spawn loop ──
    --    (evita escrever na GUI todo frame, que é desperdício)
    afkUpdateConn = task.spawn(function()
        while gui and gui.Parent do
            -- ── Tempo AFK ──
            local elapsed = tick() - afkStartTime
            local mins    = math.floor(elapsed / 60)
            local secs    = math.floor(elapsed % 60)
            afkVal.Text = string.format("%02d:%02d", mins, secs)

            if elapsed > 300 then
                afkVal.TextColor3 = Color3.fromRGB(220, 30, 30)
            elseif elapsed > 120 then
                afkVal.TextColor3 = Color3.fromRGB(255, 180, 0)
            else
                afkVal.TextColor3 = Color3.fromRGB(255, 255, 255)
            end

            -- ── Ping ──
            local ok, ping = pcall(function()
                return math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            end)
            if ok then
                pingVal.Text = ping .. " ms"
                if ping > 200 then
                    pingVal.TextColor3 = Color3.fromRGB(220, 30, 30)
                elseif ping > 100 then
                    pingVal.TextColor3 = Color3.fromRGB(255, 180, 0)
                else
                    pingVal.TextColor3 = Color3.fromRGB(50, 220, 80)
                end
            end

            -- ── FPS (do ring-buffer atualizado pelo RenderStepped) ──
            local fps = math.floor(fpsCurrent + 0.5)
            fpsVal.Text = fps .. " fps"

            if fps < 30 then
                fpsVal.TextColor3 = Color3.fromRGB(220, 30, 30)
            elseif fps < 50 then
                fpsVal.TextColor3 = Color3.fromRGB(255, 180, 0)
            else
                fpsVal.TextColor3 = Color3.fromRGB(50, 220, 80)
            end

            task.wait(0.25)
        end
    end)
end

local function StopAFKWidget()
    -- Para o loop de FPS
    if fpsConn then
        fpsConn:Disconnect()
        fpsConn = nil
    end

    -- O task.spawn loop para sozinho quando gui.Parent sumir,
    -- mas matamos a referência por segurança
    afkUpdateConn = nil

    local gui = PlayerGui:FindFirstChild("AntiAFKWidget")
    if gui then
        local frame = gui:FindFirstChild("Container")
        if frame then
            local tween = TweenService:Create(frame,
                TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                { Position = UDim2.new(1, 20, 0, 20) }
            )
            tween:Play()
            tween.Completed:Connect(function() gui:Destroy() end)
        else
            gui:Destroy()
        end
    end
end

return {
    StartAFKWidget = StartAFKWidget,
    StopAFKWidget  = StopAFKWidget,
}
