-- ── Color by FPS ─────────────────────────────────────────
function FPSCounter:FPSColor(fps)
    if fps >= 55 then return C.good
    elseif fps >= 30 then return C.mid
    else return C.bad end
end

-- ── Update bar graph ──────────────────────────────────────
function FPSCounter:UpdateBars()
    local count  = #self.bars
    local hcount = #self.history
    local maxFPS = 120

    for i = 1, count do
        local hi  = hcount - (count - i)
        local fps = (hi >= 1 and self.history[hi]) or 0
        local ratio = math.clamp(fps / maxFPS, 0, 1)
        local barH  = math.max(2, math.floor(ratio * 30))
        local col   = self:FPSColor(fps)
        local bar   = self.bars[i]
        if bar and bar.Parent then
            tween(bar, {
                Size             = UDim2.new(0, 2, 0, barH),
                BackgroundColor3 = col,
            }, 0.18, Enum.EasingStyle.Quart)
        end
    end
end

-- ── Start ─────────────────────────────────────────────────
function FPSCounter:Start()
    if self.connection then return end
    self:Create()

    -- FIX: garante que a GUI foi criada com sucesso
    if not self.gui then
        warn("[GhostHUD] Falha ao criar a GUI.")
        return
    end

    self.gui.Enabled = true

    -- FIX: inicializa lastUpdate com tick() atual para evitar divisão por zero
    self.frameCount = 0
    self.lastUpdate = tick()

    self.connection = RunService.RenderStepped:Connect(function()
        self.frameCount = self.frameCount + 1
        local now = tick()
        local elapsed = now - self.lastUpdate

        -- FIX: mínimo de 0.1s para evitar divisão por zero
        if elapsed >= 0.5 then
            local fps = math.floor(self.frameCount / elapsed)
            self.currentFPS = fps

            table.insert(self.history, fps)
            if #self.history > self.maxHistory then
                table.remove(self.history, 1)
            end

            local sum, minV = 0, math.huge
            for _, v in ipairs(self.history) do
                sum = sum + v
                if v < minV then minV = v end
            end
            local avg = math.floor(sum / #self.history)

            -- FIX: ping seguro (LocalPlayer pode ser nil)
            local ping = 0
            local lp = Players.LocalPlayer
            if lp then
                local ok, p = pcall(function() return lp:GetNetworkPing() end)
                ping = ok and math.floor(p * 1000) or 0
            end

            local col = self:FPSColor(fps)

            -- FIX: guards em todas as refs antes de usar
            if self.label and self.label.Parent then
                tween(self.label, {TextColor3 = col}, 0.2)
                self.label.Text = tostring(fps)
            end

            if self.infoLabel and self.infoLabel.Parent then
                self.infoLabel.Text = string.format(
                    "AVG  %d   ·   MIN  %d   ·   PING  %dms",
                    avg,
                    minV == math.huge and 0 or minV,
                    ping
                )
            end

            -- Pulse card border on bad fps
            if fps < 30 and self.card and self.card.Parent then
                tween(self.card, {BackgroundTransparency = 0.0}, 0.1)
                task.delay(0.1, function()
                    if self.card and self.card.Parent then
                        tween(self.card, {BackgroundTransparency = 0.12}, 0.3)
                    end
                end)
            end

            if self.dot and self.dot.Parent then
                tween(self.dot, {BackgroundColor3 = col}, 0.3)
            end

            self:UpdateBars()

            -- FIX: reset APÓS usar os valores
            self.frameCount = 0
            self.lastUpdate = now
        end
    end)
end

-- ── Stop / Toggle / Destroy ───────────────────────────────
function FPSCounter:Stop()
    if self.connection then
        self.connection:Disconnect()
        self.connection = nil
    end
    if self.gui then self.gui.Enabled = false end
end

function FPSCounter:Toggle(enabled)
    self.enabled = enabled
    if enabled then self:Start() else self:Stop() end
end

function FPSCounter:Destroy()
    self:Stop()
    if self.gui then
        self.gui:Destroy()
        self.gui    = nil
        self.card   = nil
        self.label  = nil
        self.infoLabel = nil
        self.dot    = nil
        self.botLine = nil
    end
    self.bars    = {}
    self.history = {}
end

