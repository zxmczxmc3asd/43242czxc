local function UpdateObjectCache()
    local currentTime = tick()
    if currentTime - ObjectCache.lastUpdate < ObjectCache.updateInterval then
        return
    end

    ObjectCache.parts = {}

    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency < 1 then
            local size = obj.Size
            if size.X > 0.5 or size.Y > 0.5 or size.Z > 0.5 then
                table.insert(ObjectCache.parts, obj)
            end
        end
    end

    ObjectCache.lastUpdate = currentTime
end

