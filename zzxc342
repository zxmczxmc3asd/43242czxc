    end

    if enabled then
        UpdateObjectCache()

        if ShaderState.performanceMode then
            for _, part in ipairs(ObjectCache.parts) do
                if part and part.Parent then
                    part.Reflectance = ShaderState.reflectance
                end
            end
        else
            task.spawn(function()
                local batchSize = 50
                local count = 0
                for _, part in ipairs(ObjectCache.parts) do
                    if part and part.Parent then
                        part.Reflectance = ShaderState.reflectance
                        count = count + 1
                        if count % batchSize == 0 then task.wait() end
                    end
                end
            end)
        end

        reflectanceConnection = Workspace.DescendantAdded:Connect(function(obj)
            if obj:IsA("BasePart") and obj.Transparency < 1 then
                task.wait(0.1)
                if obj and obj.Parent then
                    obj.Reflectance = ShaderState.reflectance
                end
            end
        end)
    else
        task.spawn(function()
            local batchSize = 50
            local count = 0
            for _, part in ipairs(ObjectCache.parts) do
                if part and part.Parent then
                    part.Reflectance = 0
                    count = count + 1
                    if count % batchSize == 0 then task.wait() end
                end
            end
        end)
    end

    Lighting.Technology = enabled and Enum.Technology.Future or Enum.Technology.ShadowMap
end

local function GetOrCreateEffect(className, instanceName, properties)
    local effect = Lighting:FindFirstChild(instanceName)
    if not effect then
        effect = Instance.new(className)
        effect.Name   = instanceName
        effect.Parent = Lighting
    end
    for prop, value in pairs(properties) do
        pcall(function() effect[prop] = value end)
    end
    return effect
end

-- ═══════════════════════════════════════════════════════════
--                    AUTO CYCLE SYSTEM
-- ═══════════════════════════════════════════════════════════

local autoCycleConnection = nil
local cyclePresets = {"Morning", "Midday", "Afternoon", "Evening", "Night", "Midnight"}
local currentCycleIndex = 1

local function StartAutoCycle()
    if autoCycleConnection then return end
    autoCycleConnection = RunService.Heartbeat:Connect(function()
        task.wait(60 / ShaderState.autoCycleSpeed)
        currentCycleIndex = currentCycleIndex % #cyclePresets + 1
        ApplyShaderPreset(cyclePresets[currentCycleIndex], true)
    end)
end

local function StopAutoCycle()
    if autoCycleConnection then
        autoCycleConnection:Disconnect()
        autoCycleConnection = nil
    end
end

-- ═══════════════════════════════════════════════════════════
--                    CLEANUP FUNCTION
-- ═══════════════════════════════════════════════════════════

local function Cleanup()
    StopAutoCycle()
    FPSCounter:Destroy()

    if reflectanceConnection then
        reflectanceConnection:Disconnect()
        reflectanceConnection = nil
    end

    for _, t in pairs(activeTweens) do
        if t then t:Cancel() end
    end
    activeTweens = {}
end

