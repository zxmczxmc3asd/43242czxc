-- ═══════════════════════════════════════════════════════════

ShaderModule.FPSCounter        = FPSCounter
ShaderModule.ShaderState       = ShaderState
ShaderModule.ApplyShaderPreset = ApplyShaderPreset
ShaderModule.ToggleShaders     = ToggleShaders
ShaderModule.GetOrCreateEffect = GetOrCreateEffect
ShaderModule.StartAutoCycle    = StartAutoCycle
ShaderModule.StopAutoCycle     = StopAutoCycle
ShaderModule.UpdateObjectCache = UpdateObjectCache
ShaderModule.ObjectCache       = ObjectCache
ShaderModule.Cleanup           = Cleanup

return ShaderModule
