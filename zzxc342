local activeTweens = {}

local function ApplyShaderPreset(presetName, smooth)
    local preset = ShaderPresets[presetName]
    if not preset then return end

    smooth = smooth == nil and true or smooth
    local duration = smooth and ShaderState.transitionSpeed or 0

    for _, t in pairs(activeTweens) do
        if t then t:Cancel() end
    end
    activeTweens = {}

    if duration > 0 then
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
        local goals = {
            ClockTime         = preset.ClockTime,
            Brightness        = preset.Brightness,
            Ambient           = preset.Ambient,
            OutdoorAmbient    = preset.OutdoorAmbient,
            ColorShift_Top    = preset.ColorShift_Top,
            ColorShift_Bottom = preset.ColorShift_Bottom,
            FogEnd            = preset.FogEnd,
            FogStart          = preset.FogStart
        }
        local t = TweenService:Create(Lighting, tweenInfo, goals)
        table.insert(activeTweens, t)
        t:Play()
    else
        Lighting.ClockTime         = preset.ClockTime
        Lighting.Brightness        = preset.Brightness
        Lighting.Ambient           = preset.Ambient
        Lighting.OutdoorAmbient    = preset.OutdoorAmbient
        Lighting.ColorShift_Top    = preset.ColorShift_Top
        Lighting.ColorShift_Bottom = preset.ColorShift_Bottom
        Lighting.FogEnd            = preset.FogEnd
        Lighting.FogStart          = preset.FogStart
    end
end

