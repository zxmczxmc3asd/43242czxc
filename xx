-- Ripple ao clicar
local function doRipple()
	local r = Instance.new("Frame")
	r.AnchorPoint           = Vector2.new(0.5, 0.5)
	r.Position              = UDim2.fromScale(0.5, 0.5)
	r.Size                  = UDim2.fromOffset(0, 0)
	r.BackgroundColor3      = C.redBright
	r.BackgroundTransparency = 0.45
	r.ZIndex                = 6
	Instance.new("UICorner", r).CornerRadius = UDim.new(1, 0)
	r.Parent = btn
	local target = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 1.4
	Tw:Create(r, TweenInfo.new(0.30, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size                  = UDim2.fromOffset(target, target),
		BackgroundTransparency = 1,
	}):Play()
	task.delay(0.32, function() r:Destroy() end)
end

btn.MouseButton1Down:Connect(function()
	Tw:Create(btn, tFast, { Size = SZ_PRESS }):Play()
	doRipple()
end)
btn.MouseButton1Up:Connect(function()
	Tw:Create(btn, tFast, { Size = isOver and SZ_HOVER or SZ_NORMAL }):Play()
end)

-- ─── Shine sweep ──────────────────────────────────────────────

local function doShine()
	local wrap = Instance.new("Frame")
	wrap.BackgroundTransparency = 1
	wrap.Size                   = UDim2.fromScale(1, 1)
	wrap.ClipsDescendants       = true
	wrap.ZIndex                 = 7
	wrap.Parent                 = btn

	local bar = Instance.new("Frame")
	bar.AnchorPoint      = Vector2.new(0.5, 0.5)
	bar.Position         = UDim2.fromScale(-0.2, 0.5)
	bar.Size             = UDim2.new(0, 12, 1.5, 0)
	bar.BackgroundColor3 = Color3.new(1, 1, 1)
	bar.BackgroundTransparency = 0.72
	bar.Parent           = wrap

	local g = Instance.new("UIGradient")
	g.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0,   1),
		NumberSequenceKeypoint.new(0.5, 0.2),
		NumberSequenceKeypoint.new(1,   1),
	})
	g.Rotation = 20
	g.Parent   = bar

	local tw = Tw:Create(bar,
		TweenInfo.new(0.40, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Position = UDim2.fromScale(1.2, 0.5) }
	)
	tw:Play()
	tw.Completed:Connect(function() wrap:Destroy() end)
end

-- ─── Drag (mouse + touch) ─────────────────────────────────────

local dragging = false
local dragStart, posStart

local function clampPos(pos)
	local scr  = gui.AbsoluteSize
	local half = btn.AbsoluteSize / 2
	local ax = pos.X.Scale * scr.X + pos.X.Offset
	local ay = pos.Y.Scale * scr.Y + pos.Y.Offset
	local x  = math.clamp(ax, half.X + 8, scr.X - half.X - 8)
	local y  = math.clamp(ay, half.Y + 8, scr.Y - half.Y - 8)
	return UDim2.new(
		pos.X.Scale, x - pos.X.Scale * scr.X,
		pos.Y.Scale, y - pos.Y.Scale * scr.Y
	)
end

btn.InputBegan:Connect(function(i)
	local t = i.UserInputType
	if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then
		dragging  = true
		dragStart = i.Position
		posStart  = btn.Position
		i.Changed:Connect(function()
			if i.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

btn.InputChanged:Connect(function(i)
	local t = i.UserInputType
	if (t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch) and dragging then
		local d  = i.Position - dragStart
		local np = UDim2.new(
			posStart.X.Scale, posStart.X.Offset + d.X,
			posStart.Y.Scale, posStart.Y.Offset + d.Y
		)
		btn.Position = clampPos(np)
	end
end)

