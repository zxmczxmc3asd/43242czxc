-- ─── Toggle logic ─────────────────────────────────────────────

local on     = false
local IC_OFF = "rbxasset://textures/ui/mouseLock_off.png"
local IC_ON  = "rbxasset://textures/ui/mouseLock_on.png"

local function applyState(v)
	local _, h, r = getParts()
	on = v
	lockMouse(v)
	faceCam(h, r, v)

	-- Cores conforme estado
	local strkCol  = v and C.redBright or C.red
	local strkTrns = v and 0.05        or 0.30
	local strkThk  = v and 2.8         or 1.8
	local bgCol    = v and C.bgActive  or C.bg
	local icnCol   = v and C.redBright or C.dim

	Tw:Create(strk, tMed, {
		Color        = strkCol,
		Thickness    = strkThk,
		Transparency = strkTrns,
	}):Play()
	Tw:Create(btn,  tMed, { BackgroundColor3 = bgCol }):Play()
	Tw:Create(icn,  tMed, { ImageColor3      = icnCol }):Play()

	-- Troca de ícone com rotação
	Tw:Create(icn, TweenInfo.new(0.10, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
		Rotation = v and 20 or -20,
	}):Play()
	task.delay(0.11, function()
		icn.Image    = v and IC_ON or IC_OFF
		icn.Rotation = v and -20 or 20
		Tw:Create(icn, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Rotation = 0,
		}):Play()
	end)

	doShine()
end

btn.Activated:Connect(function()
	applyState(not on)
end)

