-- ─── Utilidades ───────────────────────────────────────────────

local function NA(i)
	if not i then return end
	i.Name        = "\000"
	i.Archivable  = false
end

local function parentUI(g)
	if gethui then
		NA(g); g.Parent = gethui(); return g
	end
	local rg = CG and CG:FindFirstChild("RobloxGui")
	if rg then NA(g); g.Parent = rg; return g end
	if CG then NA(g); g.Parent = CG; return g end
	local pg = plr and plr:FindFirstChildWhichIsA("PlayerGui")
	if pg then
		NA(g); g.Parent = pg
		g.ResetOnSpawn = false
	end
	return g
end

local function getParts()
	local c = plr.Character or plr.CharacterAdded:Wait()
	local hum, hrp
	for _, d in ipairs(c:GetDescendants()) do
		if not hum and d:IsA("Humanoid")  then hum = d end
		if not hrp and d:IsA("BasePart") and d.Name == "HumanoidRootPart" then hrp = d end
		if hum and hrp then break end
	end
	return c,
		hum or c:WaitForChild("Humanoid"),
		hrp or c:WaitForChild("HumanoidRootPart")
end

local function lockMouse(v)
	if UIS.MouseEnabled then
		UIS.MouseBehavior = v
			and Enum.MouseBehavior.LockCenter
			or  Enum.MouseBehavior.Default
	end
end

-- ─── Câmera / AutoRotate ──────────────────────────────────────

local rotCon, oldAR

local function faceCam(h, hrp, v)
	if rotCon then rotCon:Disconnect(); rotCon = nil end
	if v then
		oldAR         = h.AutoRotate
		h.AutoRotate  = false
		rotCon = RS.RenderStepped:Connect(function()
			local cam = Wk.CurrentCamera
			if not (hrp and cam) then return end
			local lv   = cam.CFrame.LookVector
			local flat = Vector3.new(lv.X, 0, lv.Z)
			if flat.Magnitude > 0.0001 then
				hrp.CFrame = CFrame.lookAt(
					hrp.Position,
					hrp.Position + flat.Unit,
					Vector3.yAxis
				)
			end
		end)
	elseif oldAR ~= nil then
		h.AutoRotate = oldAR
	end
end

local function reapply(v)
	task.defer(function()
		local _, h, r = getParts()
		lockMouse(v)
		faceCam(h, r, v)
	end)
end

