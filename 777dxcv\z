-- URL do módulo de shaders (você vai hospedar no GitHub/Pastebin)
local SHADER_MODULE_URL = "https://raw.githubusercontent.com/SEU_USER/SEU_REPO/main/shader_module.lua"

-- Variável global para armazenar o módulo
_G.ShaderModule = nil
_G.ShaderLoaded = false

-- ═══════════════════════════════════════════════════════════
--                  FUNÇÃO DE CARREGAMENTO
-- ═══════════════════════════════════════════════════════════

local function LoadShaderModule()
    if _G.ShaderLoaded then 
        return _G.ShaderModule 
    end
    
    local success, result = pcall(function()
        return loadstring(game:HttpGet(SHADER_MODULE_URL))()
    end)
    
    if success then
        _G.ShaderModule = result
        _G.ShaderLoaded = true
        return result
    else
        warn("❌ Falha ao carregar Shader Module:", result)
        return nil
    end
end

