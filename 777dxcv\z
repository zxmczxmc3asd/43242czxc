-- CONTROLES
local controlSection = shadersTab:Section({ 
    Title = "🎮 Controls",
    Box = false,
    Opened = true,
})

controlSection:Button({
    Title = "🔄 Reset All Effects",
    Desc = "Restaura configurações padrão",
    Icon = "refresh-cw",
    Callback = function()
        local module = LoadShaderModule()
        if module then
            module.StopAutoCycle()
            module.ShaderState.autoCycle = false
            module.ToggleShaders(false)
            module.ApplyShaderPreset("Default", false)
            
            local Lighting = game:GetService("Lighting")
            local bloom = Lighting:FindFirstChild("Bloom")
            local blur = Lighting:FindFirstChild("Blur")
            local dof = Lighting:FindFirstChild("DepthOfField")
            local sunRays = Lighting:FindFirstChild("SunRays")
            local atmosphere = Lighting:FindFirstChild("Atmosphere")
            
            if bloom then bloom.Enabled = false; bloom.Intensity = 0.5 end
            if blur then blur.Enabled = false; blur.Size = 5 end
            if dof then dof.Enabled = false end
            if sunRays then sunRays.Enabled = false end
            if atmosphere then atmosphere.Enabled = false end
            
            module.ShaderState.reflectance = 0.3
            module.ShaderState.transitionSpeed = 1
            module.ShaderState.autoCycleSpeed = 1
            
            Notify({
                Title = "🔄 Reset Complete",
                Content = "Todas as configurações foram restauradas!",
                Duration = 3
            })
        end
    end
})

controlSection:Button({
    Title = "🗑️ Clear Cache",
    Desc = "Limpa cache de objetos",
    Icon = "trash-2",
    Callback = function()
        local module = LoadShaderModule()
        if module then
            module.ObjectCache.parts = {}
            module.ObjectCache.effects = {}
            module.ObjectCache.lastUpdate = 0
            module.UpdateObjectCache()
            
            Notify({
                Title = "🗑️ Cache Limpo",
                Content = "Cache atualizado com " .. #module.ObjectCache.parts .. " objetos",
                Duration = 2
            })
        end
    end
})

