function FPSCounter:UpdateColor(fps)
    if fps >= 55 then
        self.label.TextColor3 = Color3.fromRGB(0, 255, 0)
    elseif fps >= 30 then
        self.label.TextColor3 = Color3.fromRGB(255, 255, 0)
    else
        self.label.TextColor3 = Color3.fromRGB(255, 0, 0)
    end
end

function FPSCounter:Start()
    if self.connection then return end
    
    self:Create()
    self.gui.Enabled = true
    
    self.connection = RunService.RenderStepped:Connect(function(deltaTime)
        self.frameCount = self.frameCount + 1
        local currentTime = tick()
        
        if currentTime - self.lastUpdate >= 0.5 then
            local fps = math.floor(self.frameCount / (currentTime - self.lastUpdate))
            self.currentFPS = fps
            
            table.insert(self.history, fps)
            if #self.history > self.maxHistory then
                table.remove(self.history, 1)
            end
            
            local sum = 0
            local min = math.huge
            for _, v in ipairs(self.history) do
                sum = sum + v
                if v < min then min = v end
            end
            local avg = math.floor(sum / #self.history)
            
            self.label.Text = string.format("FPS: %d", fps)
            self.infoLabel.Text = string.format("Avg: %d | Min: %d\nPing: %d ms", 
                avg, min, math.floor(Players.LocalPlayer:GetNetworkPing() * 1000))
            
            self:UpdateColor(fps)
            
            self.frameCount = 0
            self.lastUpdate = currentTime
        end
    end)
end

function FPSCounter:Stop()
    if self.connection then
        self.connection:Disconnect()
        self.connection = nil
    end
    if self.gui then
        self.gui.Enabled = false
    end
end

function FPSCounter:Toggle(enabled)
    self.enabled = enabled
    if enabled then
        self:Start()
    else
        self:Stop()
    end
end

function FPSCounter:Destroy()
    self:Stop()
    if self.gui then
        self.gui:Destroy()
        self.gui = nil
    end
end

