-- ═══════════════════════════════════════════════════════════
--                 PERFORMANCE OPTIMIZATION
-- ═══════════════════════════════════════════════════════════

local function UpdateObjectCache()
    local currentTime = tick()
    if currentTime - ObjectCache.lastUpdate < ObjectCache.updateInterval then
        return
    end
    
    ObjectCache.parts = {}
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency < 1 then
            local size = obj.Size
            if size.X > 0.5 or size.Y > 0.5 or size.Z > 0.5 then
                table.insert(ObjectCache.parts, obj)
            end
        end
    end
    
    ObjectCache.lastUpdate = currentTime
end

-- ═══════════════════════════════════════════════════════════
--                   SHADER FUNCTIONS
-- ═══════════════════════════════════════════════════════════

local activeTweens = {}

local function ApplyShaderPreset(presetName, smooth)
    local preset = ShaderPresets[presetName]
    if not preset then return end
    
    smooth = smooth == nil and true or smooth
    local duration = smooth and ShaderState.transitionSpeed or 0
    
    for _, tween in pairs(activeTweens) do
        if tween then
            tween:Cancel()
        end
    end
    activeTweens = {}
    
    if duration > 0 then
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
        
        local goals = {
            ClockTime = preset.ClockTime,
            Brightness = preset.Brightness,
            Ambient = preset.Ambient,
            OutdoorAmbient = preset.OutdoorAmbient,
            ColorShift_Top = preset.ColorShift_Top,
            ColorShift_Bottom = preset.ColorShift_Bottom,
            FogEnd = preset.FogEnd,
            FogStart = preset.FogStart
        }
        
        local tween = TweenService:Create(Lighting, tweenInfo, goals)
        table.insert(activeTweens, tween)
        tween:Play()
    else
        Lighting.ClockTime = preset.ClockTime
        Lighting.Brightness = preset.Brightness
        Lighting.Ambient = preset.Ambient
        Lighting.OutdoorAmbient = preset.OutdoorAmbient
        Lighting.ColorShift_Top = preset.ColorShift_Top
        Lighting.ColorShift_Bottom = preset.ColorShift_Bottom
        Lighting.FogEnd = preset.FogEnd
        Lighting.FogStart = preset.FogStart
    end
end

local reflectanceConnection = nil

local function ToggleShaders(enabled)
    ShaderState.enabled = enabled
    
    if reflectanceConnection then
        reflectanceConnection:Disconnect()
        reflectanceConnection = nil
    end
    
    if enabled then
        UpdateObjectCache()
        
        if ShaderState.performanceMode then
            for _, part in ipairs(ObjectCache.parts) do
                if part and part.Parent then
                    part.Reflectance = ShaderState.reflectance
                end
            end
        else
            task.spawn(function()
                local batchSize = 50
                local count = 0
                
                for _, part in ipairs(ObjectCache.parts) do
                    if part and part.Parent then
                        part.Reflectance = ShaderState.reflectance
                        count = count + 1
                        
                        if count % batchSize == 0 then
                            task.wait()
                        end
                    end
                end
            end)
        end
        
        reflectanceConnection = Workspace.DescendantAdded:Connect(function(obj)
            if obj:IsA("BasePart") and obj.Transparency < 1 then
                task.wait(0.1)
                obj.Reflectance = ShaderState.reflectance
            end
        end)
    else
        task.spawn(function()
            local batchSize = 50
            local count = 0
            
            for _, part in ipairs(ObjectCache.parts) do
                if part and part.Parent then
                    part.Reflectance = 0
                    count = count + 1
                    
                    if count % batchSize == 0 then
                        task.wait()
                    end
                end
            end
        end)
    end
    
    Lighting.Technology = enabled and Enum.Technology.Future or Enum.Technology.ShadowMap
end

local function GetOrCreateEffect(className, instanceName, properties)
    local effect = Lighting:FindFirstChild(instanceName)
    if not effect then
        effect = Instance.new(className)
        effect.Name = instanceName
        effect.Parent = Lighting
    end
    
    for prop, value in pairs(properties) do
        pcall(function()
            effect[prop] = value
        end)
    end
    
    return effect
end

-- ═══════════════════════════════════════════════════════════
--                    AUTO CYCLE SYSTEM
-- ═══════════════════════════════════════════════════════════

local autoCycleConnection = nil
local cyclePresets = {"Morning", "Midday", "Afternoon", "Evening", "Night", "Midnight"}
local currentCycleIndex = 1

local function StartAutoCycle()
    if autoCycleConnection then return end
    
    autoCycleConnection = RunService.Heartbeat:Connect(function()
        task.wait(60 / ShaderState.autoCycleSpeed)
        
        currentCycleIndex = currentCycleIndex + 1
        if currentCycleIndex > #cyclePresets then
            currentCycleIndex = 1
        end
        
        ApplyShaderPreset(cyclePresets[currentCycleIndex], true)
    end)
end

local function StopAutoCycle()
    if autoCycleConnection then
        autoCycleConnection:Disconnect()
        autoCycleConnection = nil
    end
end

-- ═══════════════════════════════════════════════════════════
--                    CLEANUP FUNCTION
-- ═══════════════════════════════════════════════════════════

local function Cleanup()
    StopAutoCycle()
    FPSCounter:Destroy()
    
    if reflectanceConnection then
        reflectanceConnection:Disconnect()
    end
    
    for _, tween in pairs(activeTweens) do
        if tween then
            tween:Cancel()
        end
    end
end

